{
  "thresholds": {
    "min_steps": 2,
    "max_steps": 12,
    "recommended_steps": 8,
    "warn_steps": 10,
    "max_checkboxes": 10,
    "recommended_checkboxes": 8,
    "min_checkboxes": 1,
    "max_checkbox_chars": 300,
    "count_excluded_tags": []
  },

  "tag_order": ["RED", "GREEN", "INFRA", "WIRE", "E2E"],

  "sections": {
    "structure": {
      "description": "Issue body structure",
      "rules": [
        {
          "key": "what_section",
          "description": "## What section required",
          "errorMessage": "Missing '## What' section — issue must explain what is being built",
          "level": "error",
          "type": "body_match",
          "pattern": "^## What"
        },
        {
          "key": "why_section",
          "description": "## Why section required",
          "errorMessage": "Missing '## Why' section — issue must explain motivation",
          "level": "error",
          "type": "body_match",
          "pattern": "^## Why"
        },
        {
          "key": "acceptance_criteria",
          "description": "Acceptance criteria with checkboxes",
          "errorMessage": "Missing acceptance criteria — needs '## Acceptance criteria' with ≥1 checkbox",
          "level": "error",
          "type": "section_has_checkboxes",
          "section": "## Acceptance criteria"
        },
        {
          "key": "step_count",
          "description": "Step count within allowed range",
          "errorMessage": "Step count {actual} outside allowed range ({min}-{max})",
          "level": "error",
          "type": "step_count"
        },
        {
          "key": "step_numbering",
          "description": "Sequential step numbering (no gaps or duplicates)",
          "errorMessage": "Step numbering gap: expected Step {expected}, found Step {actual}",
          "level": "error",
          "type": "step_numbering"
        },
        {
          "key": "step_title_em_dash",
          "description": "Step titles use em dash (—) not hyphen",
          "errorMessage": "Step {step} title uses hyphen instead of em dash (—)",
          "level": "error",
          "type": "step_title_format"
        }
      ]
    },

    "sizing": {
      "description": "Step and checkbox sizing limits",
      "rules": [
        {
          "key": "empty_step",
          "description": "No empty steps",
          "errorMessage": "Empty step — no checkboxes found",
          "level": "error",
          "type": "step_not_empty"
        },
        {
          "key": "checkbox_count_error",
          "description": "Hard checkbox limit per step",
          "errorMessage": "{count} checkboxes — maximum is {max}, split this step",
          "level": "error",
          "type": "checkbox_count_max"
        },
        {
          "key": "checkbox_count_warn",
          "description": "Recommended checkbox limit per step",
          "errorMessage": "{count} checkboxes — recommended maximum is {recommended}",
          "level": "warn",
          "type": "checkbox_count_recommended"
        },
        {
          "key": "checkbox_length",
          "description": "Checkbox text length limit",
          "errorMessage": "Checkbox > {max} chars — break into multiple: {preview}...",
          "level": "warn",
          "type": "checkbox_text_length"
        },
        {
          "key": "checkbox_not_empty",
          "description": "Checkbox must have description after tag",
          "errorMessage": "Empty checkbox text after [{tag}] — needs a description",
          "level": "error",
          "type": "checkbox_text_not_empty"
        }
      ]
    },

    "tag_chains": {
      "description": "Tag dependency and ordering rules",
      "rules": [
        {
          "key": "green_requires_red",
          "description": "[GREEN] requires [RED] in same step",
          "errorMessage": "[GREEN] without [RED] — needs a failing test first (or should be [INFRA])",
          "level": "error",
          "type": "tag_requires",
          "tag": "GREEN",
          "requires": "RED"
        },
        {
          "key": "tag_ordering",
          "description": "Tags must follow defined order",
          "errorMessage": "Tag order: [{tag}] out of sequence — expected: {order}",
          "level": "warn",
          "type": "tag_ordering"
        },
        {
          "key": "e2e_without_red",
          "description": "[E2E] without [RED] is fragile coverage",
          "errorMessage": "[E2E] without [RED] — E2E tests without unit tests is fragile coverage",
          "level": "error",
          "type": "tag_recommended_with",
          "tag": "RED",
          "when_any": ["E2E"]
        }
      ]
    },

    "tag_semantics": {
      "description": "Per-tag content validation",
      "rules": [
        {
          "key": "red_mentions_test",
          "description": "[RED] must mention test/spec",
          "errorMessage": "[RED] doesn't mention a test — RED is for writing failing tests",
          "level": "error",
          "type": "tag_content_match",
          "tag": "RED",
          "pattern": "test|spec|_test|\\.test"
        },
        {
          "key": "red_no_consecutive",
          "description": "No consecutive [RED] without [GREEN]",
          "errorMessage": "[RED] after [RED] without [GREEN] — horizontal TDD (write one test, implement, repeat)",
          "level": "error",
          "type": "tag_no_consecutive",
          "tag": "RED",
          "separator": "GREEN"
        },
        {
          "key": "green_no_consecutive",
          "description": "No consecutive [GREEN] without [RED]",
          "errorMessage": "[GREEN] after [GREEN] without [RED] — each implementation needs a failing test first",
          "level": "error",
          "type": "tag_no_consecutive",
          "tag": "GREEN",
          "separator": "RED"
        },
        {
          "key": "green_before_red",
          "description": "[GREEN] can't appear before any [RED]",
          "errorMessage": "[GREEN] appears before [RED] — test must come first",
          "level": "error",
          "type": "tag_requires_before",
          "tag": "GREEN",
          "requires": "RED"
        },
        {
          "key": "green_writes_tests",
          "description": "[GREEN] shouldn't mention writing tests",
          "errorMessage": "[GREEN] mentions writing tests — should this be [RED]?",
          "level": "warn",
          "type": "tag_content_reject",
          "tag": "GREEN",
          "pattern": "\\bwrite\\b.*\\btest\\b|\\bcreate\\b.*\\btest\\b"
        },
        {
          "key": "e2e_mentions_test",
          "description": "[E2E] must mention test/spec/playwright",
          "errorMessage": "[E2E] doesn't mention a test — E2E is for writing Playwright tests",
          "level": "error",
          "type": "tag_content_match",
          "tag": "E2E",
          "pattern": "test|spec|\\.spec|playwright"
        },
        {
          "key": "wire_mentions_integration",
          "description": "[WIRE] should mention integration/connection",
          "errorMessage": "[WIRE] doesn't mention integration/connection between layers",
          "level": "warn",
          "type": "tag_content_match",
          "tag": "WIRE",
          "pattern": "connect|integrat|endpoint|frontend.*backend|backend.*frontend"
        },
        {
          "key": "infra_writes_tests",
          "description": "[INFRA] shouldn't mention writing tests",
          "errorMessage": "[INFRA] mentions writing tests — should this be [RED] or [E2E]?",
          "level": "warn",
          "type": "tag_content_reject",
          "tag": "INFRA",
          "pattern": "\\bwrite\\b.*\\btest\\b|\\bcreate\\b.*\\btest\\b"
        },
        {
          "key": "no_duplicate_checkboxes",
          "description": "No duplicate checkbox text in same step",
          "errorMessage": "Duplicate checkbox: {text}",
          "level": "error",
          "type": "no_duplicates"
        }
      ]
    }
  }
}
